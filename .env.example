# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Dynamically provided by context, but used for OAuth redirect registration.
APP_URL="MY_APP_URL"

# MongoDB Connection String
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/dbname"

# JWT Secret for session tokens
JWT_SECRET="generate-a-secure-random-string-here"
JWT_EXPIRES_IN="43200"

# Email Configuration (Nodemailer)
# For SMTP Service:
# - EMAIL_HOST: SMTP provider host (e.g., mail.smtp2go.com)
# - EMAIL_PORT: SMTP port (e.g., 2525 or 587)
# - EMAIL_USER: SMTP username
# - EMAIL_PASS: SMTP password
EMAIL_HOST="smtp.example.com"
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASS=""
# EMAIL_FROM: Must be a valid sender email address (e.g., mailer@example.com)
EMAIL_FROM=""

# Google OAuth Credentials
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Add these "Authorized redirect URIs":
#    - https://ais-dev-rfpxeharzta5kokkad2yno-350097616864.asia-southeast1.run.app/api/auth/google/callback
#    - https://ais-pre-rfpxeharzta5kokkad2yno-350097616864.asia-southeast1.run.app/api/auth/google/callback
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Authentik OAuth Credentials
# 1. Create a Provider and Application in Authentik
# 2. Add these "Redirect URIs":
#    - https://ais-dev-rfpxeharzta5kokkad2yno-350097616864.asia-southeast1.run.app/api/auth/authentik/callback
#    - https://ais-pre-rfpxeharzta5kokkad2yno-350097616864.asia-southeast1.run.app/api/auth/authentik/callback
AUTHENTIK_URL="https://your-authentik-domain.com"
AUTHENTIK_CLIENT_ID="YOUR_AUTHENTIK_CLIENT_ID"
AUTHENTIK_CLIENT_SECRET="YOUR_AUTHENTIK_CLIENT_SECRET"

# Google Maps Platform Key
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_KEY_HERE"
