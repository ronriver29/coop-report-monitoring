# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Dynamically provided by context, but used for OAuth redirect registration.
APP_URL="MY_APP_URL"

# MongoDB Connection String
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/dbname"

# JWT Secret for session tokens
JWT_SECRET="generate-a-secure-random-string-here"
JWT_EXPIRES_IN="43200"

# Email Configuration (Nodemailer)
# For SMTP2GO:
# - EMAIL_HOST: mail.smtp2go.com
# - EMAIL_PORT: 2525 or 587
# - EMAIL_USER: your smtp2go username
# - EMAIL_PASS: your smtp2go password
# For GMAIL:
# - EMAIL_HOST: smtp.gmail.com
# - EMAIL_PORT: 587
# - EMAIL_USER: your email@gmail.com
# - EMAIL_PASS: your-google-app-password
EMAIL_SERVICE=""
EMAIL_HOST="smtp.example.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER=""
EMAIL_PASS=""
# EMAIL_FROM: Must be a valid email address (e.g., your-email@gmail.com)
EMAIL_FROM=""

# Google OAuth Credentials
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Add these "Authorized redirect URIs":
#    - https://ais-dev-rfpxeharzta5kokkad2yno-350097616864.asia-southeast1.run.app/api/auth/google/callback
#    - https://ais-pre-rfpxeharzta5kokkad2yno-350097616864.asia-southeast1.run.app/api/auth/google/callback
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Frontend Configuration (for GitHub Pages deployment)
# Set this to your backend API URL (e.g., https://your-app.run.app)
VITE_API_BASE_URL=""
